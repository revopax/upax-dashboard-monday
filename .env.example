# ===============================================================
# UPAX Dashboard Monday — Variables de Entorno
# ===============================================================
#
# SETUP RAPIDO:
#   1. cp .env.example .env.local
#   2. Llena los valores marcados con <<OBLIGATORIO>>
#   3. npm install
#   4. npm run dev
#
# EN VERCEL (produccion):
#   Settings > Environment Variables > agregar cada variable
#
# PEDIR A FRANCO los valores que no puedas generar tu mismo.
# ===============================================================


# ===============================================================
# 1. MONDAY.COM
# ===============================================================

# <<OBLIGATORIO>> Token de API de Monday
# Donde obtenerlo: monday.com > click en tu avatar > Developers > My Access Tokens
# Copiar el token completo (empieza con eyJ...)
MONDAY_API_KEY=

# Board ID del tablero de Marketing Corporativo
# No cambiar a menos que se migre a otro board
MONDAY_BOARD_ID=18044324200


# ===============================================================
# 2. GOOGLE SHEETS (Forecast / GDD)
# ===============================================================

# <<OBLIGATORIO>> Service Account JSON completo
# Donde obtenerlo:
#   1. Google Cloud Console > IAM & Admin > Service Accounts
#   2. Seleccionar la cuenta "upax-sheets-reader@upax-dashboard"
#   3. Keys > Add Key > Create new key > JSON
#   4. Pegar TODO el contenido del JSON descargado aqui (en una sola linea)
# IMPORTANTE: el JSON debe incluir las llaves {} y todo el contenido
GOOGLE_SERVICE_ACCOUNT_JSON=

# <<OBLIGATORIO>> ID del spreadsheet de Forecast 2026
# Es el valor entre /d/ y /edit en la URL del Google Sheet
# Sheet actual: "Budget GDD 2026 (Escalonado)"
SHEETS_GDD_SPREADSHEET_ID=1Xd1CFY4gwxmKV8OHti9a1XjCmO2Q5NtUlGulfgbxtaE

# Nombre de la pestana con KPIs semanales
SHEETS_GDD_TAB_NAME=KPIs_Weekly

# URL publica de exportacion CSV del sheet GDD
# Donde obtenerlo: Google Sheets > Archivo > Compartir > Publicar en la web > CSV
# Seleccionar la pestana correcta y copiar el link
SHEETS_GDD_CSV_URL=


# ===============================================================
# 3. HUBSPOT
# ===============================================================

# <<OBLIGATORIO>> Token de Private App de HubSpot
# Donde obtenerlo:
#   1. HubSpot > Settings (engrane) > Integrations > Private Apps
#   2. Crear nueva app o usar la existente de "UPAX Dashboard"
#   3. Scopes necesarios: crm.objects.contacts.read, crm.objects.deals.read
#   4. Copiar el token (empieza con pat-...)
# IMPORTANTE: el codigo lee HUBSPOT_PRIVATE_APP_TOKEN (NO "HUBSPOT_TOKEN")
HUBSPOT_PRIVATE_APP_TOKEN=


# ===============================================================
# 4. SLACK
# ===============================================================

# <<OBLIGATORIO>> Bot token de Slack para enviar minutas
# Donde obtenerlo:
#   1. api.slack.com > Your Apps > seleccionar la app del dashboard
#   2. OAuth & Permissions > Bot User OAuth Token
#   3. Copiar el token (empieza con xoxb-...)
#   Scope necesario: chat:write
# Si no tienes acceso, pedir a Franco que te agregue como colaborador en la app
SLACK_BOT_TOKEN=

# Canal donde se envian las minutas del weekly
# C081Z8R4ZH9 = #admin-mkt-minutas (no cambiar sin avisar a Franco)
SLACK_CHANNEL=C081Z8R4ZH9


# ===============================================================
# 5. VERCEL KV (Upstash Redis) — almacenamiento persistente
# ===============================================================
# Estas variables se configuran AUTOMATICAMENTE al vincular un KV Store:
#   Vercel > Project > Settings > Storage > Connect Store > Create KV Database
# Si ya existe el store, solo vincularlo al proyecto y Vercel las inyecta.
# Solo llenar manualmente si trabajas en local sin Vercel CLI.

KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=


# ===============================================================
# 6. AUTENTICACION
# ===============================================================

# <<OBLIGATORIO>> Password del dashboard (el browser muestra dialogo de login)
# Definir uno nuevo para el equipo. Todos los que accedan usan el mismo password.
# Usuario: cualquiera (se ignora). Password: este valor.
DASHBOARD_PASSWORD=

# <<OBLIGATORIO>> API Secret — protege TODAS las rutas API (GET y POST)
# Generar un valor nuevo con: openssl rand -hex 32
# AMBAS variables deben tener EL MISMO valor:
API_SECRET=
NEXT_PUBLIC_API_SECRET=

# CRON_SECRET — protege endpoints de cron (/api/cron/*) y backfill
# En Vercel se configura automaticamente con Vercel Cron Jobs
# Solo llenar si corres crons manualmente en local
CRON_SECRET=


# ===============================================================
# 7. VARIABLES INYECTADAS POR VERCEL (NO configurar manualmente)
# ===============================================================
# Vercel las setea automaticamente en cada deploy. Se documentan solo como referencia:
# NX_DAEMON, TURBO_CACHE, TURBO_DOWNLOAD_LOCAL_ENABLED, TURBO_REMOTE_ONLY,
# TURBO_RUN_SUMMARY, VERCEL, VERCEL_ENV, VERCEL_URL, VERCEL_TARGET_ENV,
# VERCEL_GIT_COMMIT_*, VERCEL_GIT_PROVIDER, VERCEL_GIT_REPO_*, VERCEL_OIDC_TOKEN
