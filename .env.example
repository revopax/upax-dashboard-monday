# ===============================================================
# UPAX Dashboard Monday — Variables de Entorno
# Copiar a .env.local para desarrollo local:
#   cp .env.example .env.local
# En Vercel: Settings > Environment Variables
# ===============================================================

# ---------------------------------------------------------------
# Monday.com API
# Obtener en monday.com > Avatar > Developers > My Access Tokens
# ---------------------------------------------------------------
MONDAY_API_KEY=
# Board ID — el numero en la URL al abrir el board (default: 18044324200)
MONDAY_BOARD_ID=18044324200

# ---------------------------------------------------------------
# Google Sheets — Service Account JSON para leer targets GDD/Forecast
# Crear en Google Cloud Console > IAM > Service Accounts > Keys > JSON
# Pegar el JSON completo como valor (con las llaves {})
# ---------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID del spreadsheet de Forecast/GDD (el valor entre /d/ y /edit en la URL)
SHEETS_GDD_SPREADSHEET_ID=
# Nombre de la pestana con KPIs semanales (default: KPIs_Weekly)
SHEETS_GDD_TAB_NAME=KPIs_Weekly
# URL publica de exportacion CSV del sheet GDD (legacy, actualmente no se usa en produccion)
SHEETS_GDD_CSV_URL=

# ---------------------------------------------------------------
# HubSpot — Private App token para consultar Leads, MQLs, SQLs, Opps
# Crear en HubSpot > Settings > Integrations > Private Apps > Create
# Scopes necesarios: crm.objects.contacts.read, crm.objects.deals.read
# IMPORTANTE: el codigo lee HUBSPOT_PRIVATE_APP_TOKEN (no HUBSPOT_TOKEN)
# ---------------------------------------------------------------
HUBSPOT_PRIVATE_APP_TOKEN=

# ---------------------------------------------------------------
# Slack — Bot token para enviar minutas al canal
# Crear en api.slack.com > Your Apps > OAuth & Permissions
# Scope necesario: chat:write
# ---------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_CHANNEL=C081Z8R4ZH9

# ---------------------------------------------------------------
# Vercel KV (Upstash Redis) — almacenamiento persistente
# Se configura automaticamente al vincular un KV Store en Vercel Dashboard
# (Settings > Storage > Connect Store)
# Si configuras manualmente, necesitas estos 4:
# ---------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
# Alias aceptados (Upstash directo, se usan como fallback):
# UPSTASH_REDIS_REST_URL (= KV_REST_API_URL)
# UPSTASH_REDIS_REST_TOKEN (= KV_REST_API_TOKEN)
REDIS_URL=

# ---------------------------------------------------------------
# Autenticacion
# ---------------------------------------------------------------
# Password para Basic Auth del dashboard (browser muestra dialogo de login)
DASHBOARD_PASSWORD=
# API Secret — protege TODAS las rutas API (GET y POST)
# Generar un valor aleatorio seguro: openssl rand -hex 32
# AMBAS variables deben tener el MISMO valor:
# - API_SECRET: usado server-side en API routes
# - NEXT_PUBLIC_API_SECRET: expuesto al browser para enviar en Authorization header
API_SECRET=
NEXT_PUBLIC_API_SECRET=
# CRON_SECRET — protege endpoints de cron y backfill
# En Vercel se configura automaticamente con Vercel Cron Jobs
CRON_SECRET=

# ---------------------------------------------------------------
# Variables INYECTADAS POR VERCEL (NO configurar manualmente)
# Se documentan aqui para referencia — Vercel las setea automaticamente:
# ---------------------------------------------------------------
# NX_DAEMON=false
# TURBO_CACHE, TURBO_DOWNLOAD_LOCAL_ENABLED, TURBO_REMOTE_ONLY, TURBO_RUN_SUMMARY
# VERCEL, VERCEL_ENV, VERCEL_URL, VERCEL_TARGET_ENV
# VERCEL_GIT_COMMIT_*, VERCEL_GIT_PROVIDER, VERCEL_GIT_REPO_*, VERCEL_OIDC_TOKEN
